{
    "version": 2,
    "routes": [
      { "src": "^/$", "dest": "/public/index.html" },
      { "src": "^/api/(.*)", "dest": "/index.js" },
      { "src": "^(.*)$", "dest": "/public/index.html" }
    ],
    "rewrites": [
      { "source": "/api/(.*)", "destination": "index.js" },    
      { "source": "/(.*)", "destination": "/public/index.html" }
    ]
  }